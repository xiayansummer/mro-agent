# Runtime
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=mro_agent_dev

# AI API (OpenAI-compatible)
AI_API_KEY=your_api_key
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-plus
AI_VISION_MODEL=qwen-vl-plus

# Memos memory service
MEMOS_URL=http://localhost:5230
MEMOS_ACCESS_TOKEN=
MEMOS_USERNAME=mro-admin
MEMOS_PASSWORD=

# Registration invite token.
# Empty means open registration in development. Production requires a non-empty value.
REGISTER_TOKEN=
